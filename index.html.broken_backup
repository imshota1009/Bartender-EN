        .shaker-liquid-wave {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 100%;
            background: inherit;
            animation: liquid-wave 0.15s ease-in-out infinite alternate;
        }

        @keyframes liquid-wave {
            0% {
                transform: translateY(0) skewX(-5deg);
                border-radius: 0 0 5px 5px;
            }

            100% {
                transform: translateY(-5px) skewX(5deg);
                border-radius: 5px 5px 0 0;
            }
        }

